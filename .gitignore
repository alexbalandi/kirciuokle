# --- Node / build ---
node_modules/
dist/
.wrangler/
.cloudflare/
*.tsbuildinfo

# --- secrets & local config ---
.env
.env.*
!.env.example
.dev.vars
.claude/settings.local.json

# --- python envs & caches ---
__pycache__/
.venv-train/
local/app/.venv/
.scratch/

# --- generated data, models, corpora (never committed; see README License) ---
local/data/
local/tagger-hf/data/
local/tagger-hf/runs/
local/tagger-hf/artifacts/
local/tagger-hf/release/hf-*/
local/accentuator/data/
local/accentuator/onnx/*.onnx
local/accentuator/joint/checkpoints/
local/accentuator/joint/data/
local/accentuator/joint/data-literary/
local/accentuator/joint/data-round2/
local/accentuator/joint/pruned/
local/accentuator/joint/hf_release/

# --- browser pilot / local-model bundle ---

# --- transient artifacts (screenshots, logs) — never source ---
*.png
*.log
docs-*.png
test-results/
playwright-report/
test/playwright/
output/

# local-mode model bundle (generated by scripts/prepare_local_model.py)
/local-model/

# spellcheck dictionaries — generated/fetched build artifacts, like the model.
# Regenerate with: uv run scripts/regenerate_spellcheck_dicts.py
# lt.dic/lt.aff are the BSD-3 hunspell accept dictionary (see ATTRIBUTIONS).
/public/spellcheck-lt.txt
/public/spellcheck-bigrams.txt
/public/lt.dic
/public/lt.aff

# stray model weights dropped at repo root (e.g. test download artifacts) — never source
/*.onnx
