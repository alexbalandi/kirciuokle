{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vitest/globals", "node", "@cloudflare/workers-types"]
  },
  "include": [
    "test/**/*.ts",
    "src/client/spellcheck.ts",
    "src/client/i18n.ts",
    "src/client/format.ts",
    "src/client/local/**/*.ts",
    "src/worker/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
